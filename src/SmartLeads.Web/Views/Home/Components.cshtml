@{
    ViewData["Title"] = "Component Sections";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<div class="row g-6">
    <!-- Table Action & Brand Components -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Table & Action Components</h5>
                <i class="icon-base bx bx-code-alt cursor-pointer" data-bs-toggle="modal" data-bs-target="#codeModal" data-code-target="#tableActionCode" title="View Code"></i>
            </div>
            <div class="card-body">
                <div class="row g-6 align-items-center">

                    <!-- 1. Gtr Identity with Round Photo -->
                    <div class="col-md-4">
                        <small class="text-muted d-block mb-3">Identity (Avatar + Text)</small>
                        <div class="d-flex align-items-center gap-2">
                            <div class="avatar avatar-sm">
                                <!-- Round Photo -->
                                <img src="~/gtlib/dependencylib/sneatlayout/assets/img/avatars/1.png" alt="Gtr" class="rounded-circle border border-2 border-light shadow-sm" />
                            </div>
                            <span class="fw-bold h5 mb-0 text-dark">Gtr</span>
                        </div>
                    </div>

                    <!-- 2. Tabulator Cell: View + PDF Icon -->
                    <div class="col-md-4">
                        <small class="text-muted d-block mb-3">Tabulator Cell Action</small>
                        <div class="d-inline-flex align-items-center">
                            <a href="javascript:void(0);" class="d-flex align-items-center gap-1 text-decoration-none py-1">
                                <span class="text-primary fw-medium fs-5">View</span>
                                <!-- Scaled PDF Icon -->
                                <i class='icon-base bx bxs-file-pdf text-danger' style="font-size: 1.8rem;"></i>
                            </a>
                        </div>
                    </div>

                    <!-- 3. PDF Action Dropdown Button -->
                    <div class="col-md-4">
                        <small class="text-muted d-block mb-3">PDF Dropdown Action</small>
                        <div class="dropdown">
                            <button class="btn border bg-white rounded-4 px-4 py-2 d-flex align-items-center shadow-none dropdown-toggle hide-arrow"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="border-color: #e0e0e0 !important;">

                                <div class="position-relative me-3 d-flex align-items-center">
                                    <i class='icon-base bx bx-file fs-3 text-dark'></i>
                                    <span class="position-absolute start-50 top-50 translate-middle mt-1 fw-black text-dark" style="font-size: 7px; font-weight: 900;">PDF</span>
                                </div>
                                <i class='icon-base bx bx-chevron-down fs-4 ms-auto text-muted'></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li><a class="dropdown-item" href="javascript:void(0);"><i class='bx bx-download me-2'></i> Download PDF</a></li>
                                <li><a class="dropdown-item" href="javascript:void(0);"><i class='bx bx-printer me-2'></i> Print</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="javascript:void(0);"><i class='bx bx-trash me-2'></i> Delete</a></li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
            <div class="d-none" id="tableActionCode">
<pre><code class="language-html">&lt;!-- Brand Round Photo --&gt;
&lt;div class="d-flex align-items-center gap-2"&gt;
    &lt;div class="avatar avatar-sm"&gt;
        &lt;img src="path/to/img.png" class="rounded-circle" /&gt;
    &lt;/div&gt;
    &lt;span class="fw-bold"&gt;Gtr&lt;/span&gt;
&lt;/div&gt;

&lt;!-- View + PDF (Optimized for Table Cell) --&gt;
&lt;a href="#" class="d-flex align-items-center gap-1 text-primary"&gt;
    &lt;span class="fs-5"&gt;View&lt;/span&gt;
    &lt;i class='bx bxs-file-pdf text-danger' style="font-size: 1.8rem;"&gt;&lt;/i&gt;
&lt;/a&gt;

&lt;!-- PDF Dropdown Button --&gt;
&lt;div class="dropdown"&gt;
    &lt;button class="btn border rounded-4 d-flex align-items-center dropdown-toggle hide-arrow" data-bs-toggle="dropdown"&gt;
        &lt;i class='bx bx-file fs-3'&gt;&lt;/i&gt;
        &lt;i class='bx bx-chevron-down ms-auto'&gt;&lt;/i&gt;
    &lt;/button&gt;
    &lt;ul class="dropdown-menu"&gt;
        &lt;li&gt;&lt;a class="dropdown-item" href="#"&gt;Download PDF&lt;/a&gt;&lt;/li&gt;
    &lt;/ul&gt;
&lt;/div&gt;</code></pre>
            </div>
        </div>
    </div>
    <!-- Buttons Section -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Buttons</h5>
                <i class="icon-base bx bx-code-alt cursor-pointer" data-bs-toggle="modal" data-bs-target="#codeModal" data-code-target="#buttonsCode" title="View Code"></i>
            </div>
            <div class="card-body">
                <small class="fw-medium">Basic Buttons</small>
                <div class="demo-inline-spacing mt-2">
                    <button type="button" class="btn btn-outline-primary">Primary</button>
                    <button type="button" class="btn btn-outline-dark">Secondary</button>
                </div>
            </div>
            <div class="d-none" id="buttonsCode">
<pre><code class="language-html">&lt;small class=&quot;fw-medium&quot;&gt;Basic Buttons&lt;/small&gt;
&lt;div class=&quot;demo-inline-spacing mt-2&quot;&gt;
    &lt;button type=&quot;button&quot; class=&quot;btn btn-outline-primary&quot;&gt;Primary&lt;/button&gt;
    &lt;button type=&quot;button&quot; class=&quot;btn btn-outline-dark&quot;&gt;Secondary&lt;/button&gt;
&lt;/div&gt;</code></pre>
            </div>
        </div>
    </div>

    <!-- Inputs and Labels Section -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Inputs & Labels</h5>
                <i class="icon-base bx bx-code-alt cursor-pointer" data-bs-toggle="modal" data-bs-target="#codeModal" data-code-target="#inputsLabelsCode" title="View Code"></i>
            </div>
            <div class="card-body">
                <div class="row g-6">
                    <div class="col-md-6">
                        <label for="firstNameInput" class="form-label">First Name</label>
                        <input type="text" class="form-control" id="firstNameInput" placeholder="Jane" />
                    </div>
                    <div class="col-md-6">
                        <label for="lastNameInput" class="form-label">Last Name</label>
                        <input type="text" class="form-control" id="lastNameInput" placeholder="Doe" />
                    </div>
                    <div class="col-md-6">
                        <label for="defaultFormControlInput" class="form-label">Username</label>
                        <input type="text" class="form-control" id="defaultFormControlInput" placeholder="johndoe" />
                    </div>
                    <div class="col-md-6">
                        <label for="phoneNumberInput"
                               class="form-label">
                            Phone Number
                        </label>
                        <input type="text"
                               class="form-control js-international-phone-number-input"
                               id="phoneNumberInput"
                               name="PhoneNumber"
                               placeholder="+880 1XXXXXXXXX"
                               aria-describedby="phoneNumberError" />
                        <div id="phoneNumberError"
                             class="form-text text-danger js-international-phone-number-error-message"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="basic-addon-search31">Search</label>
                        <div class="input-group input-group-merge">
                            <span class="input-group-text" id="basic-addon-search31"><i class="icon-base bx bx-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search..." aria-label="Search..." aria-describedby="basic-addon-search31" />
                        </div>
                    </div>
                    <div class="col-md-6 form-password-toggle">
                        <label class="form-label" for="basic-default-password32">Password</label>
                        <div class="input-group input-group-merge">
                            <input type="password" class="form-control" id="basic-default-password32" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" aria-describedby="basic-default-password" />
                            <span class="input-group-text cursor-pointer" id="basic-default-password"><i class="icon-base bx bx-hide"></i></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="emailInput" class="form-label">Email</label>
                        <input type="email" class="form-control" id="emailInput" placeholder="jane.doe@example.com" />
                    </div>
                    <div class="col-md-6">
                        <label for="numberInput" class="form-label">Number</label>
                        <input type="number" class="form-control" id="numberInput" placeholder="42" />
                    </div>
                    <div class="col-md-6">
                        <label for="urlInput" class="form-label">URL</label>
                        <input type="url" class="form-control" id="urlInput" placeholder="https://example.com" />
                    </div>

                    <div class="col-md-6">
                        <label for="colorInput" class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color" id="colorInput" value="#563d7c" title="Choose your color" />
                    </div>
                </div>
            </div>
            <div class="d-none" id="inputsLabelsCode">
