&lt;div class=&quot;row g-6 mt-4&quot;&gt;
    &lt;div class=&quot;col-12&quot;&gt;&lt;small class=&quot;fw-medium&quot;&gt;Sizes&lt;/small&gt;&lt;/div&gt;
    &lt;div class=&quot;col-md-6&quot;&gt;
