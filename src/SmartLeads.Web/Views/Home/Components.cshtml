@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const codeModal = document.getElementById('codeModal');
            if(codeModal) {
                const copyCodeBtn = document.getElementById('copyCodeBtn');
                let codeToCopy = '';

                codeModal.addEventListener('show.bs.modal', function (event) {
                    const triggerElement = event.relatedTarget;
                    const codeTargetSelector = triggerElement.getAttribute('data-code-target');
                    const codeTargetElement = document.querySelector(codeTargetSelector);
                    const codeBlock = codeModal.querySelector('.modal-body pre code');
                    const modalTitle = codeModal.querySelector('.modal-title');

                    // Get section title from card-header
                    const cardHeader = triggerElement.closest('.card-header');
                    const sectionTitle = cardHeader.querySelector('h5').textContent;
                    modalTitle.textContent = `Code View: ${sectionTitle}`;

                    if (codeTargetElement) {
                        const rawCode = codeTargetElement.querySelector('code').innerHTML;
                        codeBlock.innerHTML = rawCode;
                        codeToCopy = new DOMParser().parseFromString(rawCode, "text/html").documentElement.textContent;

                        // Re-highlight the code
                        if (window.hljs) {
                            window.hljs.highlightElement(codeBlock);
                        }
                    }
                });

                copyCodeBtn.addEventListener('click', function () {
                    if (codeToCopy) {
                        navigator.clipboard.writeText(codeToCopy).then(() => {
                            copyCodeBtn.textContent = 'Copied!';
                            setTimeout(() => {
                                copyCodeBtn.textContent = 'Copy';
                            }, 2000);
                        }).catch(err => {
                            console.error('Failed to copy text: ', err);
                        });
                    }
                });
            }

            // SweetAlert2
            const successBtn = document.getElementById('type-success');
            if (successBtn) {
                successBtn.onclick = function () {
                    Swal.fire({
                        title: 'Good job!',
                        text: 'You clicked the button!',
                        icon: 'success',
                        customClass: {
                            confirmButton: 'btn btn-primary'
                        },
                        buttonsStyling: false
                    });
                };
            }
            const infoBtn = document.getElementById('type-info');
            if (infoBtn) {
                infoBtn.onclick = function () {
                    Swal.fire({
                        title: 'Info!',
                        text: 'You clicked the button!',
                        icon: 'info',
                        customClass: {
                            confirmButton: 'btn btn-primary'
                        },
                        buttonsStyling: false
                    });
                };
            }
            const warningBtn = document.getElementById('type-warning');
            if (warningBtn) {
                warningBtn.onclick = function () {
                    Swal.fire({
                        title: 'Warning!',
                        text: 'You clicked the button!',
                        icon: 'warning',
                        customClass: {
                            confirmButton: 'btn btn-primary'
                        },
                        buttonsStyling: false
                    });
                };
            }
            const errorBtn = document.getElementById('type-error');
            if (errorBtn) {
                errorBtn.onclick = function () {
                    Swal.fire({
                        title: 'Error!',
                        text: 'You clicked the button!',
                        icon: 'error',
                        customClass: {
                            confirmButton: 'btn btn-primary'
                        },
                        buttonsStyling: false
                    });
                };
            }
            const questionBtn = document.getElementById('type-question');
            if (questionBtn) {
                questionBtn.onclick = function () {
                    Swal.fire({
                        title: 'Question!',
                        text: 'You clicked the button!',
                        icon: 'question',
                        customClass: {
                            confirmButton: 'btn btn-primary'
                        },
                        buttonsStyling: false
                    });
                };
            }
            const autoCloseBtn = document.getElementById('auto-close');
            if (autoCloseBtn) {
                autoCloseBtn.onclick = function () {
                    Swal.fire({
                        title: 'Auto close alert!',
                        html: 'I will close in <b></b> milliseconds.',
                        timer: 2000,
                        timerProgressBar: true,
                        didOpen: () => {
                            Swal.showLoading();
                            const b = Swal.getHtmlContainer().querySelector('b');
                            timerInterval = setInterval(() => {
                                b.textContent = Swal.getTimerLeft();
                            }, 100);
                        },
                        willClose: () => {
                            clearInterval(timerInterval);
                        }
                    });
                };
            }
            const confirmColorBtn = document.getElementById('confirm-color');
            if (confirmColorBtn) {
                confirmColorBtn.onclick = function () {
                    Swal.fire({
                        title: 'Are you sure?',
                        text: "You won't be able to revert this!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, delete it!',
                        customClass: {
                            confirmButton: 'btn btn-primary me-3',
                            cancelButton: 'btn btn-label-secondary'
                        },
                        buttonsStyling: false
                    }).then(function (result) {
                        if (result.value) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted!',
                                text: 'Your file has been deleted.',
                                customClass: {
                                    confirmButton: 'btn btn-success'
                                }
                            });
                        }
                    });
                };
            }

            // Event Listeners for toastr buttons
            document.getElementById('toastr-success').addEventListener('click', function () {
                toastr.success('This is a success message!', 'Success');
            });
            document.getElementById('toastr-info').addEventListener('click', function () {
                toastr.info('This is an info message!', 'Info');
            });
            document.getElementById('toastr-warning').addEventListener('click', function () {
                toastr.warning('This is a warning message!', 'Warning');
            });
            document.getElementById('toastr-error').addEventListener('click', function () {
                toastr.error('This is an error message!', 'Error');
            });
        });
    </script>

