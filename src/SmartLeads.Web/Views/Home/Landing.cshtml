@{
    ViewData["Title"] = "SmartLeads - Contact & Lead Management";
    Layout = "_AuthLayout";
}

<div class="landing-container">
    <!-- Header with SmartLeads Branding -->
    <div class="landing-header text-center mb-5">
        <h2 class="h3 mb-1">
            Smart<span class="highlight">Leads</span>
        </h2>
        <p class="text-muted">Manage your contacts and leads efficiently</p>
    </div>

    <!-- Hero Section -->
    <div class="landing-hero mb-4">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-5 fw-bold hero-title mb-3">Manage Your Contacts & Leads Efficiently</h1>
                <p class="lead mb-4">
                    SmartLeads is a modern contact and lead management system designed to help businesses 
                    organize, track, and nurture their relationships. Streamline your workflow and boost 
                    productivity with our intuitive platform.
                </p>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@Url.Action("CreateCompany", "Home")" class="btn btn-primary btn-lg px-4">
                        <i class='bx bx-plus-circle me-2'></i>Create Company
                    </a>
                    <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-primary btn-lg px-4">
                        <i class='bx bx-log-in me-2'></i>Login
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="300" height="300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-primary hero-illustration">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <line x1="19" y1="8" x2="19" y2="14"></line>
                    <line x1="22" y1="11" x2="16" y2="11"></line>
                    <rect x="3" y="14" width="12" height="8" rx="2"></rect>
                    <line x1="9" y1="18" x2="9" y2="18"></line>
                    <line x1="13" y1="16" x2="13" y2="16"></line>
                </svg>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="py-5">
        <h2 class="text-center h3 mb-5">Why Choose SmartLeads?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-primary rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-book-contacts fs-3'></i>
                        </div>
                        <h5 class="card-title">Contact Management</h5>
                        <p class="card-text text-muted">
                            Organize all your contacts in one place. Add, edit, and manage contact details 
                            with ease. Keep track of every interaction and never miss a follow-up.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-success rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-search fs-3'></i>
                        </div>
                        <h5 class="card-title">Quick Search</h5>
                        <p class="card-text text-muted">
                            Find contacts instantly with our powerful search functionality. Filter by name, 
                            company, email, or any other criteria to locate the information you need.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-info rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-shield-quarter fs-3'></i>
                        </div>
                        <h5 class="card-title">Secure & Private</h5>
                        <p class="card-text text-muted">
                            Your data security is our priority. We use industry-standard encryption and 
                            security practices to keep your information safe and private.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-warning rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-building fs-3'></i>
                        </div>
                        <h5 class="card-title">Company Management</h5>
                        <p class="card-text text-muted">
                            Create and manage multiple companies. Organize contacts by company and 
                            streamline your business operations with company-specific insights.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-danger rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-analyse fs-3'></i>
                        </div>
                        <h5 class="card-title">Lead Tracking</h5>
                        <p class="card-text text-muted">
                            Track your leads through every stage of your sales pipeline. Monitor progress, 
                            set reminders, and convert more leads into customers.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm feature-card">
                    <div class="card-body text-center p-4">
                        <div class="badge bg-secondary rounded-circle p-3 mb-3" style="width: 60px; height: 60px;">
                            <i class='bx bx-cloud fs-3'></i>
                        </div>
                        <h5 class="card-title">Cloud-Based</h5>
                        <p class="card-text text-muted">
                            Access your contacts from anywhere, on any device. Your data is securely 
                            stored in the cloud and synchronized in real-time.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <div class="cta-section text-center py-5 mb-4">
        <h2 class="h3 mb-2">Ready to Get Started?</h2>
        <p class="lead text-muted mb-4">Create your company account today and start managing your leads efficiently.</p>
        <a href="@Url.Action("CreateCompany", "Home")" class="btn btn-primary btn-lg px-5 py-3">
            <i class='bx bx-rocket me-2'></i>Create Your Company Now
        </a>
    </div>
</div>
