@{
    ViewData["Title"] = "User Invitations";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">User Invitations</h5>
        <button type="button" class="btn btn-primary" onclick="openInviteModal()">
            <i class='bx bx-plus me-1'></i> Invite User
        </button>
    </div>
    <div class="card-body">
        <!-- Tabulator Table -->
        <div id="invitationsTable"></div>

        <!-- Empty State -->
        <div id="emptyState" class="text-center py-5" style="display: none;">
            <i class='bx bx-envelope fs-1 text-muted mb-3'></i>
            <p class="text-muted">No invitations found. Invite team members to join your company!</p>
        </div>
    </div>
</div>

<!-- Invite User Modal -->
<div class="modal fade" id="inviteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class='bx bx-envelope me-2'></i>Invite User
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="inviteForm">
                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="email" id="email" class="form-control" placeholder="name@example.com" required />
                            <label class="form-label">Email Address *</label>
                        </div>
                        <span class="text-danger" id="emailError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <select id="role" class="form-select">
                                <option value="0">User</option>
                                <option value="1">Admin</option>
                                <option value="2">Manager</option>
                            </select>
                            <label class="form-label">Role</label>
                        </div>
                        <span class="text-danger" id="roleError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <select id="expiryDays" class="form-select">
                                <option value="1">1 Day</option>
                                <option value="3">3 Days</option>
                                <option value="7" selected>7 Days</option>
                                <option value="14">14 Days</option>
                                <option value="30">30 Days</option>
                            </select>
                            <label class="form-label">Invitation Valid For</label>
                        </div>
                        <span class="text-danger" id="expiryDaysError"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                    <i class='bx bx-x me-1'></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="sendInvitation()">
                    <i class='bx bx-send me-1'></i> <span id="sendButtonText">Send Invitation</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <script src="~/js/invitations/index.js"></script>
}
