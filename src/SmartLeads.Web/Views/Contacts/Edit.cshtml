@model SmartLeads.Application.Contacts.Models.ContactDto

@{
    ViewData["Title"] = "Edit Contact";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="icon-base bx bx-edit me-2"></i>Edit Contact
        </h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input name="FirstName" value="@Model.FirstName" class="form-control" placeholder="First Name" />
                        <label name="FirstName" class="form-label">First Name</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input name="LastName" value="@Model.LastName" class="form-control" placeholder="Last Name" />
                        <label name="LastName" class="form-label">Last Name</label>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input name="Email" value="@Model.Email" class="form-control" placeholder="Email" />
                    <label name="Email" class="form-label">Email</label>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" placeholder="Phone Number" />
                    <label name="PhoneNumber" class="form-label">Phone Number</label>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input name="Company" value="@Model.Company" class="form-control" placeholder="Company" />
                    <label name="Company" class="form-label">Company</label>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input name="JobTitle" value="@Model.JobTitle" class="form-control" placeholder="Job Title" />
                    <label name="JobTitle" class="form-label">Job Title</label>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <textarea name="Address" class="form-control" placeholder="Address" rows="3">@Model.Address</textarea>
                    <label name="Address" class="form-label">Address</label>
                </div>
            </div>
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="icon-base bx bx-check me-1"></i> Update Contact
                </button>
                <a asp-action="Index" class="btn btn-label-secondary">
                    <i class="icon-base bx bx-x me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
