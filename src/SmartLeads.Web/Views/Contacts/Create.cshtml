@model SmartLeads.Application.Contacts.Commands.CreateContact.CreateContactCommand

@{
    ViewData["Title"] = "Create Contact";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="icon-base bx bx-user-plus me-2"></i>Create New Contact
        </h5>
    </div>
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                        <label asp-for="FirstName" class="form-label"></label>
                    </div>
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                        <label asp-for="LastName" class="form-label"></label>
                    </div>
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email" class="form-label"></label>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                    <label asp-for="PhoneNumber" class="form-label"></label>
                </div>
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input asp-for="Company" class="form-control" placeholder="Company" />
                    <label asp-for="Company" class="form-label"></label>
                </div>
                <span asp-validation-for="Company" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <input asp-for="JobTitle" class="form-control" placeholder="Job Title" />
                    <label asp-for="JobTitle" class="form-label"></label>
                </div>
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <div class="form-floating">
                    <textarea asp-for="Address" class="form-control" placeholder="Address" rows="3"></textarea>
                    <label asp-for="Address" class="form-label"></label>
                </div>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="icon-base bx bx-check me-1"></i> Save Contact
                </button>
                <a asp-action="Index" class="btn btn-label-secondary">
                    <i class="icon-base bx bx-x me-1"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
