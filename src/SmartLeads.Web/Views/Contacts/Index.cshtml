@{
    ViewData["Title"] = "Contacts";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">My Contacts</h5>
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">
            <i class="icon-base bx bx-plus me-1"></i> Add Contact
        </button>
    </div>
    <div class="card-body">
        <!-- Toolbar: Search and Column Filter -->
        <div class="row align-items-center mb-3">
            <div class="col-6">
                <!-- Search Input -->
                <div class="input-group">
                    <span class="input-group-text"><i class="icon-base bx bx-search"></i></span>
                    <input id="searchInput" type="text" class="form-control" placeholder="Search contacts..." />
                </div>
            </div>
            <div class="col-6 d-flex justify-content-end">
                <div class="dropdown d-inline-block">
                    <button class="btn btn-outline-primary" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="icon-base bx bx-cog fs-5"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end gear-dropdown1" aria-labelledby="dropdownMenuButton1">
                        <div class="row p-4 main-dropdown-size overflow-hidden">
                            <div class="col">
                                <span class="fw-bold ms-3">Columns</span>
                                <hr class="m-0 w-75 ms-3 w-sm-50" />
                                <ul class="list-unstyled" id="ContactsColumnList">
                                    <!-- Column checkboxes will be populated here -->
                                </ul>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="p-4">
                                <button id="saveContactsFilter" class="btn btn-outline-primary">Save Filter</button>
                            </div>
                            <div class="p-4">
                                <button id="deleteContactsFilter" class="btn btn-outline-danger" onclick="DeleteFilter_Contacts('Contacts')">Remove Filter</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabulator Table -->
        <div id="contactsTable"></div>

        <!-- Empty State -->
        <div id="emptyState" class="text-center py-5" style="display: none;">
            <i class="icon-base bx bx-book-contacts fs-1 text-muted mb-3"></i>
            <p class="text-muted">No contacts found. Add your first contact!</p>
        </div>
    </div>
</div>

<!-- Create/Edit Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Contact</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="contactForm">
                    <input type="hidden" id="contactId" value="" />
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" id="firstName" class="form-control" placeholder="First Name" required />
                                <label class="form-label">First Name *</label>
                            </div>
                            <span class="text-danger" id="firstNameError"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" id="lastName" class="form-control" placeholder="Last Name" required />
                                <label class="form-label">Last Name *</label>
                            </div>
                            <span class="text-danger" id="lastNameError"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="email" id="email" class="form-control" placeholder="name@example.com" />
                            <label class="form-label">Email</label>
                        </div>
                        <span class="text-danger" id="emailError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="tel" id="phoneNumber" class="form-control" placeholder="Phone Number" />
                            <label class="form-label">Phone Number</label>
                        </div>
                        <span class="text-danger" id="phoneNumberError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="text" id="company" class="form-control" placeholder="Company" />
                            <label class="form-label">Company</label>
                        </div>
                        <span class="text-danger" id="companyError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="text" id="jobTitle" class="form-control" placeholder="Job Title" />
                            <label class="form-label">Job Title</label>
                        </div>
                        <span class="text-danger" id="jobTitleError"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating">
                            <textarea id="address" class="form-control" placeholder="Address" rows="3"></textarea>
                            <label class="form-label">Address</label>
                        </div>
                        <span class="text-danger" id="addressError"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                    <i class="icon-base bx bx-x me-1"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveContact()">
                    <i class="icon-base bx bx-check me-1"></i> <span id="saveButtonText">Save Contact</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to delete this contact?</p>
                <p class="text-danger fw-semibold mt-2">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                    <i class="icon-base bx bx-trash me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tabulator Table Initialization and AJAX Handling for Contacts
        let contactsTable;
        let deleteContactId = null;
        let searchQuery = '';

        // Define table columns
        var TableFields = [
            { title: "Name", field: "fullName", width: 250, hozAlign: "left", visible: true,
                formatter: function(cell, formatterParams, onRendered) {
                    const data = cell.getData();
                    const initials = (data.firstName[0] || '') + (data.lastName[0] || '');
                    return `
                        <div class="d-flex align-items-center">
                            <div class="avatar avatar-sm me-3">
                                <span class="avatar-initial rounded-circle bg-label-primary">
                                    ${initials}
                                </span>
                            </div>
                            <div>
                                <span class="fw-semibold">${data.firstName} ${data.lastName}</span>
                            </div>
                        </div>
                    `;
                }
            },
            { title: "Email", field: "email", width: 200, hozAlign: "left", visible: true,
                formatter: function(cell) {
                    const email = cell.getValue();
                    return email ? `<a href="mailto:${email}" class="text-decoration-none">${email}</a>` : '<span class="text-muted">-</span>';
                }
            },
            { title: "Phone", field: "phoneNumber", width: 150, hozAlign: "left", visible: true,
                formatter: function(cell) {
                    const phone = cell.getValue();
                    return phone ? `<a href="tel:${phone}" class="text-decoration-none">${phone}</a>` : '<span class="text-muted">-</span>';
                }
            },
            { title: "Company", field: "company", width: 150, hozAlign: "left", visible: true },
            { title: "Job Title", field: "jobTitle", width: 150, hozAlign: "left", visible: true },
            { title: "Address", field: "address", width: 200, hozAlign: "left", visible: false },
            {
                title: "Actions",
                field: "id",
                width: 120,
                hozAlign: "center",
                frozen: true,
                visible: true,
                download: false,
                print: false,
                formatter: function(cell) {
                    const id = cell.getValue();
                    return `
                        <div class="d-flex gap-1 justify-content-center">
                            <button type="button" class="btn btn-sm btn-icon btn-label-primary" onclick="openEditModal(${id})" title="Edit">
                                <i class="icon-base bx bx-edit-alt"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-icon btn-label-danger" onclick="openDeleteModal(${id})" title="Delete">
                                <i class="icon-base bx bx-trash"></i>
                            </button>
                        </div>
                    `;
                }
            }
        ];

        // Initialize on document ready
        $(document).ready(function() {
            ContactsGear();
            setupSearchFilter();
        });

        // Load column filter settings and initialize table
        function ContactsGear() {
            $.ajax({
                url: '@Url.Action("GetFilteredColumn", "ColumnFilter")',
                type: 'GET',
                data: { type: 'Contacts' },
                success: function (response) {
                    console.log("GetFilteredColumn response:", response);
                    
                    if ((response.Success == 1 || response.success == 1) && response.data && response.data.keyValue) {
                        try {
                            const savedData = JSON.parse(response.data.keyValue);
                            console.log("Parsed saved data:", savedData);
                            
                            if (savedData.colDefs && Array.isArray(savedData.colDefs)) {
                                // Reorder TableFields based on saved order
                                const newTableFields = [];
                                
                                // First add columns in saved order
                                savedData.colDefs.forEach(savedCol => {
                                    const tableCol = TableFields.find(col => col.field === savedCol.field);
                                    if (tableCol) {
                                        tableCol.visible = savedCol.visible !== undefined ? savedCol.visible : true;
                                        newTableFields.push(tableCol);
                                    }
                                });
                                
                                // Then add any new columns that weren't in saved config (like Actions)
                                TableFields.forEach(col => {
                                    if (!newTableFields.find(c => c.field === col.field)) {
                                        newTableFields.push(col);
                                    }
                                });
                                
                                // Replace TableFields with reordered array
                                TableFields.length = 0;
                                TableFields.push(...newTableFields);
                                
                                console.log("Updated TableFields:", TableFields);
                            }
                        } catch (e) {
                            console.error("Error parsing saved columns:", e);
                        }
                    }
                    populateCheckbox();
                    initializeTabulator();
                },
                error: function (error) {
                    console.error("Error fetching column settings:", error);
                    populateCheckbox();
                    initializeTabulator();
                }
            });
        }

        // Populate column filter checkboxes
        function populateCheckbox() {
            let items = TableFields
                .filter(x => x.field !== 'id') // Exclude actions column
                .map(x => {
                    return `
                        <li class="d-flex justify-content-between align-items-center px-3 py-1 draggable-item" data-field="${x.field}">
                            <span class="d-flex align-items-center">
                                <i class="icon-base bx bx-menu me-2 handle" style="cursor: move;"></i> ${x.title}
                            </span>
                            <div class="form-check form-switch">
                                <input class="form-check-input toggle-column contacts-column" type="checkbox" role="switch"
                                       id="${x.field}" value="${x.field}" ${x.visible ? 'checked' : ''}
                                       onclick="showHideColumn('${x.field}')">
                            </div>
                        </li>`;
                });

            const columnList = document.getElementById('ContactsColumnList');
            columnList.innerHTML = items.join('');
            enableDragAndDrop();
        }

        // Enable drag and drop for column ordering
        function enableDragAndDrop() {
            new Sortable(document.getElementById('ContactsColumnList'), {
                animation: 200,
                handle: '.handle',
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                dragClass: 'sortable-drag',
                forceFallback: true,
                fallbackTolerance: 5,
                scroll: true,
                scrollSensitivity: 30,
                scrollSpeed: 10,
                onEnd: function (evt) {
                    updateColumnOrder();
                }
            });
        }

        // Update column order based on drag and drop
        function updateColumnOrder() {
            let newOrder = [];
            document.querySelectorAll('#ContactsColumnList .draggable-item').forEach(item => {
                const field = item.getAttribute('data-field');
                const title = item.querySelector('span').innerText.trim();
                const visible = item.querySelector('input').checked;
                newOrder.push({ field: field, title: title, visible: visible });
            });

            let allColumns = contactsTable.getColumns().map(col => col.getDefinition());
            let fixedColumns = allColumns.filter(col => col.field === 'id');
            let newColumns = newOrder.map(col => {
                let existingColumn = contactsTable.getColumn(col.field);
                return existingColumn ? existingColumn.getDefinition() : { title: col.title, field: col.field, visible: col.visible };
            });

            newColumns = [...newColumns, ...fixedColumns];
            contactsTable.setColumns(newColumns);

            // Update TableFields array to match new order (for saving)
            const actionColumn = TableFields.find(col => col.field === 'id');
            TableFields = newColumns;
            if (actionColumn && !TableFields.find(col => col.field === 'id')) {
                TableFields.push(actionColumn);
            }

            // Re-populate checkboxes
            populateCheckbox();
        }

        // Show/hide individual column
        function showHideColumn(colName) {
            contactsTable.toggleColumn(colName);
        }

        // Save column filter settings
        $("#saveContactsFilter").on("click", function () {
            var colDefs = contactsTable.getColumnDefinitions();

            $(".contacts-column").each(function () {
                var field = $(this).val();
                var isVisible = $(this).is(":checked");

                colDefs.forEach(function (colDef) {
                    if (colDef.field === field) {
                        colDef.visible = isVisible;
                    }
                });
            });

            var filteredColDefs = colDefs.filter(colDef => colDef.field !== 'id');
            var finaldata = { colDefs: filteredColDefs };
            var jsonData = JSON.stringify(finaldata);

            console.log("Saving column filter:", jsonData);

            $.ajax({
                url: '@Url.Action("ColumnFilterCreation", "ColumnFilter")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ keyValue: jsonData, type: 'Contacts' }),
                success: function (response) {
                    console.log("Save response:", response);
                    // Handle both Success and success (case-insensitive)
                    if (response.Success === 1 || response.success === 1 || response.Success === true || response.success === true) {
                        toastr.success(response.Message || response.message || "Filter saved successfully", "Success", { "toastClass": "toast-green" });
                        $('#dropdownMenuButton1').dropdown('hide');
                    } else {
                        toastr.error(response.Message || response.message || "Unknown error", "Error");
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Save error:", xhr.responseText, status, error);
                    // Try to parse error response
                    try {
                        var errResponse = JSON.parse(xhr.responseText);
                        toastr.error(errResponse.Message || errResponse.message || "Error saving filter settings.", "Error");
                    } catch (e) {
                        toastr.error("Error saving filter settings.", "Error");
                    }
                }
            });
        });

        // Delete column filter settings
        function DeleteFilter_Contacts(data) {
            $.ajax({
                url: '@Url.Action("DeleteColumnFilter", "ColumnFilter")',
                type: "GET",
                data: { type: data },
                success: function (response) {
                    console.log("Delete response:", response);
                    if (response.Success == 1 || response.success == 1) {
                        toastr.success(response.Message || response.message || "Deleted successfully", "Success", { "toastClass": "toast-green" });
                        ContactsGear();
                    } else {
                        toastr.error(response.Message || response.message || "Error deleting filter", "Error", { "toastClass": "toast-red" });
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Delete error:", xhr.responseText);
                    toastr.error("Error during delete.", "Error", { "toastClass": "toast-red" });
                }
            });
        }

        // Close dropdown when clicking outside
        document.addEventListener("click", function (event) {
            let dropdown = document.querySelector(".gear-dropdown1");
            let button = document.getElementById("dropdownMenuButton1");
            if (dropdown && button && !dropdown.contains(event.target) && !button.contains(event.target)) {
                dropdown.classList.remove("show");
            }
        });

        document.querySelector(".gear-dropdown1").addEventListener("click", function (event) {
            event.stopPropagation();
        });

        // Initialize Tabulator table
        function initializeTabulator() {
            contactsTable = new Tabulator("#contactsTable", {
                data: [],
                dataLoader: true,
                layout: "fitColumns",
                placeholder: "No contacts found",
                pagination: true,
                paginationSize: 10,
                paginationSizeSelector: [10, 25, 50, 100],
                columns: TableFields,
                ajaxConfig: "GET",
                ajaxResponse: function(url, params, response) {
                    return response;
                },
                dataLoaded: function(data) {
                    toggleEmptyState(data.length === 0);
                }
            });

            // Load data
            loadContacts();
        }

        // Load contacts from API
        function loadContacts() {
            $.ajax({
                url: '/api/contacts',
                type: 'GET',
                dataType: 'json',
                success: function(response) {
                    const contacts = response.map(contact => ({
                        ...contact,
                        fullName: `${contact.firstName} ${contact.lastName}`
                    }));
                    contactsTable.setData(contacts);
                },
                error: function(xhr) {
                    showToast('Error loading contacts', 'error');
                }
            });
        }

        // Setup search filter
        function setupSearchFilter() {
            $('#searchInput').on('input', function() {
                clearTimeout(window.searchDebounce);
                window.searchDebounce = setTimeout(() => {
                    searchQuery = $(this).val().trim();
                    contactsTable.setFilter([
                        { field: "firstName", type: "like", value: searchQuery },
                        { field: "lastName", type: "like", value: searchQuery },
                        { field: "email", type: "like", value: searchQuery },
                        { field: "company", type: "like", value: searchQuery }
                    ]);
                }, 300);
            });
        }

        // Toggle empty state visibility
        function toggleEmptyState(show) {
            if (show) {
                $('#emptyState').fadeIn();
                $('#contactsTable').hide();
            } else {
                $('#emptyState').hide();
                $('#contactsTable').fadeIn();
            }
        }

        // Open Create Modal
        function openCreateModal() {
            resetForm();
            $('#modalTitle').text('Add Contact');
            $('#saveButtonText').text('Save Contact');
            $('#contactId').val('');
            $('#contactModal').modal('show');
        }

        // Open Edit Modal
        function openEditModal(id) {
            $.ajax({
                url: `/api/contacts/${id}`,
                type: 'GET',
                dataType: 'json',
                success: function(contact) {
                    resetForm();
                    $('#modalTitle').text('Edit Contact');
                    $('#saveButtonText').text('Update Contact');
                    $('#contactId').val(contact.id);
                    $('#firstName').val(contact.firstName);
                    $('#lastName').val(contact.lastName);
                    $('#email').val(contact.email);
                    $('#phoneNumber').val(contact.phoneNumber);
                    $('#company').val(contact.company);
                    $('#jobTitle').val(contact.jobTitle);
                    $('#address').val(contact.address);
                    $('#contactModal').modal('show');
                },
                error: function(xhr) {
                    showToast('Error loading contact details', 'error');
                }
            });
        }

        // Save Contact (Create or Update)
        function saveContact() {
            clearErrors();
            
            const contactId = $('#contactId').val();
            const data = {
                firstName: $('#firstName').val().trim(),
                lastName: $('#lastName').val().trim(),
                email: $('#email').val().trim(),
                phoneNumber: $('#phoneNumber').val().trim(),
                company: $('#company').val().trim(),
                jobTitle: $('#jobTitle').val().trim(),
                address: $('#address').val().trim()
            };

            // Basic validation
            let isValid = true;
            if (!data.firstName) {
                $('#firstNameError').text('First name is required');
                isValid = false;
            }
            if (!data.lastName) {
                $('#lastNameError').text('Last name is required');
                isValid = false;
            }
            if (data.email && !validateEmail(data.email)) {
                $('#emailError').text('Invalid email format');
                isValid = false;
            }

            if (!isValid) return;

            const url = contactId ? `/api/contacts/${contactId}` : '/api/contacts';
            const method = contactId ? 'PUT' : 'POST';

            const payload = contactId 
                ? { id: parseInt(contactId), ...data }
                : data;

            $.ajax({
                url: url,
                type: method,
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function(response) {
                    $('#contactModal').modal('hide');
                    showToast(contactId ? 'Contact updated successfully' : 'Contact created successfully', 'success');
                    loadContacts();
                },
                error: function(xhr) {
                    if (xhr.responseJSON && xhr.responseJSON.errors) {
                        xhr.responseJSON.errors.forEach(error => {
                            showToast(error, 'error');
                        });
                    } else {
                        showToast('Error saving contact', 'error');
                    }
                }
            });
        }

        // Open Delete Modal
        function openDeleteModal(id) {
            deleteContactId = id;
            $('#deleteModal').modal('show');
        }

        // Confirm Delete
        function confirmDelete() {
            if (!deleteContactId) return;

            $.ajax({
                url: `/api/contacts/${deleteContactId}`,
                type: 'DELETE',
                success: function(response) {
                    $('#deleteModal').modal('hide');
                    showToast('Contact deleted successfully', 'success');
                    loadContacts();
                },
                error: function(xhr) {
                    showToast('Error deleting contact', 'error');
                }
            });
        }

        // Reset form fields
        function resetForm() {
            $('#contactForm')[0].reset();
            clearErrors();
        }

        // Clear validation errors
        function clearErrors() {
            $('.text-danger').text('');
        }

        // Show toast notification
        function showToast(message, type = 'success') {
            const options = {
                closeButton: true,
                debug: false,
                newestOnTop: true,
                progressBar: true,
                positionClass: "toast-top-right",
                preventDuplicates: true,
                onclick: null,
                showDuration: "300",
                hideDuration: "1000",
                timeOut: "3000",
                extendedTimeOut: "1000",
                showEasing: "swing",
                hideEasing: "linear",
                showMethod: "fadeIn",
                hideMethod: "fadeOut"
            };

            if (type === 'error') {
                toastr.error(message, 'Error', options);
            } else if (type === 'success') {
                toastr.success(message, 'Success', options);
            } else if (type === 'warning') {
                toastr.warning(message, 'Warning', options);
            } else if (type === 'info') {
                toastr.info(message, 'Info', options);
            }
        }

        // Close modal on escape key
        $(document).on('keydown', function(e) {
            if (e.key === 'Escape') {
                $('.modal').modal('hide');
            }
        });
    </script>
}
