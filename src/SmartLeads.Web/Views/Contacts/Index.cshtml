@model IEnumerable<SmartLeads.Application.Contacts.Models.ContactDto>

@{
    ViewData["Title"] = "Contacts";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">My Contacts</h5>
        <a asp-action="Create" class="btn btn-primary">
            <i class="icon-base bx bx-plus me-1"></i> Add Contact
        </a>
    </div>
    <div class="card-datatable table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Company</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-3">
                                        <span class="avatar-initial rounded-circle bg-label-primary">
                                            @item.FirstName[0]@item.LastName[0]
                                        </span>
                                    </div>
                                    <div>
                                        <span class="fw-semibold">@item.FirstName @item.LastName</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a>
                            </td>
                            <td>
                                <a href="tel:@item.PhoneNumber" class="text-decoration-none">@item.PhoneNumber</a>
                            </td>
                            <td>@item.Company</td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="icon-base bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="icon-base bx bx-edit-alt me-1"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Are you sure you want to delete this contact?');">
                                                <i class="icon-base bx bx-trash me-1"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">
                            <div class="py-5">
                                <i class="icon-base bx bx-book-contacts fs-1 text-muted mb-3"></i>
                                <p class="text-muted">No contacts found. Add your first contact!</p>
                                <a asp-action="Create" class="btn btn-primary">Add Contact</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
