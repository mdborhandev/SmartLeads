@{
    ViewData["Title"] = "Reset Link Sent";
    Layout = "_AuthLayout";
}

<div class="text-center">
    <div class="mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-envelope-check text-success" viewBox="0 0 16 16">
            <path d="M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-.966-.741l5.64-3.471L8 9.583l7-4.2V8.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2zm3.708 6.208L1 11.105V5.383zM1 4.217 4.708 6.5 1 8.783z"/>
            <path d="M16 12.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0m-1.992-1.507a.5.5 0 0 0-.716.692l1 1a.5.5 0 0 0 .708 0l2-2a.5.5 0 1 0-.708-.708z"/>
        </svg>
    </div>
    
    <h4 class="mb-3">Check Your Email</h4>
    <p class="text-body-secondary mb-4">
        If an account exists with the email you provided, we've sent a password reset link to that address.
    </p>
    
    <div class="alert alert-warning" role="alert">
        <p class="mb-0"><strong>Didn't receive the email?</strong> Check your spam folder or try again.</p>
    </div>

    <div class="mt-4">
        <a asp-action="ForgotPassword" class="btn btn-outline-primary">Try Again</a>
        <a asp-action="Login" class="btn btn-link text-decoration-none ms-2">Back to Login</a>
    </div>
</div>
