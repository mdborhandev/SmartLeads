@model SmartLeads.Web.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<form id="forgot-password" method="post">
    <h4 class="mb-4">Forgot Password? 🔒</h4>
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Enter your email address and we'll send you a link to reset your password.</p>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
        <label asp-for="Email" class="form-label"></label>
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <button id="forgot-password-submit" type="submit" class="btn btn-primary d-grid w-100 mb-3">Send Reset Link</button>

    <div class="text-center">
        <a asp-action="Login" class="text-decoration-none">← Back to login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
