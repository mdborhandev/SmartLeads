@model SmartLeads.Domain.DTOs.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<form id="forgot-password">
    @Html.AntiForgeryToken()
    <h4 class="mb-4">Forgot Password? 🔒</h4>
    <div id="error-message" class="alert alert-danger" role="alert" style="display: none;"></div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Enter your email address and we'll send you a link to reset your password.</p>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
        <label asp-for="Email" class="form-label"></label>
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <button id="forgot-password-submit" type="submit" class="btn btn-primary d-grid w-100 mb-3">
        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
        <span>Send Reset Link</span>
    </button>

    <div class="text-center">
        <a asp-action="Login" class="text-decoration-none">← Back to login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('#forgot-password').on('submit', function(e) {
                e.preventDefault();
                
                var $form = $(this);
                var $button = $('#forgot-password-submit');
                var $spinner = $button.find('.spinner-border');
                var $buttonText = $button.find('span:not(.spinner-border)');
                var $errorMessage = $('#error-message');
                
                // Validate form
                if (!$form.valid()) {
                    return false;
                }
                
                // Show loading state
                $button.prop('disabled', true);
                $spinner.removeClass('d-none');
                $buttonText.text('Sending...');
                $errorMessage.hide();
                
                // Get anti-forgery token
                var token = $form.find('input[name="__RequestVerificationToken"]').val();
                
                // Send AJAX request
                $.ajax({
                    url: '@Url.Action("ApiForgotPassword", "Auth")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    data: JSON.stringify({
                        email: $('#Email').val()
                    }),
                    success: function(response) {
                        // Show success message
                        toastr.success(response.message, 'Success');
                        
                        // Redirect to confirmation page
                        setTimeout(function() {
                            window.location.href = '@Url.Action("ForgotPasswordConfirmation", "Auth")';
                        }, 1000);
                    },
                    error: function(xhr) {
                        var response = xhr.responseJSON;
                        $errorMessage.text(response?.message || 'An error occurred. Please try again.');
                        $errorMessage.show();
                        
                        // Reset button state
                        $button.prop('disabled', false);
                        $spinner.addClass('d-none');
                        $buttonText.text('Send Reset Link');
                    }
                });
                
                return false;
            });
        });
    </script>
}
