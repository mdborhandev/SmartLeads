@{
    ViewData["Title"] = "User List";
}

@Html.AntiForgeryToken()

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Users</h5>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal" onclick="openCreateModal()">
            <i class="bx bx-plus me-1"></i> Invite User
        </button>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bx bx-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row g-3 align-items-center mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bx bx-search"></i></span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by username, email, name, employee ID, department, or designation..." />
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-grid d-md-flex justify-content-md-end gap-2">
                    <!-- Column Filter Dropdown -->
                    <div class="dropdown d-inline-block">
                        <button class="btn btn-outline-primary" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bx bx-cog"></i>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end gear-dropdown1" aria-labelledby="dropdownMenuButton1">
                            <div class="row p-4 main-dropdown-size overflow-hidden">
                                <div class="col">
                                    <span class="fw-bold ms-3">Columns</span>
                                    <hr class="m-0 w-75 ms-3 w-sm-50" />
                                    <ul class="list-unstyled" id="UsersColumnList">
                                        <!-- Column checkboxes will be populated here -->
                                    </ul>
                                </div>
                            </div>
                            <div class="d-flex">
                                <div class="p-4">
                                    <button id="saveUsersFilter" class="btn btn-outline-primary">Save Filter</button>
                                </div>
                                <div class="p-4">
                                    <button id="deleteUsersFilter" class="btn btn-outline-danger" onclick="DeleteFilter_Users('Users')">Remove Filter</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Export Dropdown -->
                    <div class="dropdown">
                        <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bx bx-export me-1"></i> Export
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><button type="button" class="dropdown-item" id="exportCsvBtn">CSV</button></li>
                            <li><button type="button" class="dropdown-item" id="exportExcelBtn">Excel</button></li>
                            <li><button type="button" class="dropdown-item" id="exportPdfBtn">PDF</button></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div id="userTable"></div>
    </div>
</div>

<!-- User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Invite User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="userForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="userId" name="Id" />
                    <input type="hidden" id="formAction" value="create" />
                    
                    <div class="alert alert-info" id="invitationNotice">
                        <i class="bx bx-info-circle me-2"></i>
                        <strong>Note:</strong> An invitation email will be sent to the user. They will set their own password upon accepting the invitation.
                    </div>
                    
                    <h6 class="mb-3">Basic Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" class="form-control" id="username" name="Username" required />
                            <span class="text-danger" id="usernameError"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="Email" required />
                            <span class="text-danger" id="emailError"></span>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firstName" class="form-label">First Name</label>
                            <input type="text" class="form-control" id="firstName" name="FirstName" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="lastName" class="form-label">Last Name</label>
                            <input type="text" class="form-control" id="lastName" name="LastName" />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="role" class="form-label">Role</label>
                            <select class="form-select" id="role" name="Role" required>
                                <option value="0">User</option>
                                <option value="1">Admin</option>
                                <option value="2">Manager</option>
                                <option value="3">Super Admin</option>
                            </select>
                            <span class="text-danger" id="roleError"></span>
                        </div>
                    </div>
                    
                    <hr class="my-4" />
                    
                    <h6 class="mb-3">Employee Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="employeeId" class="form-label">Employee ID</label>
                            <input type="text" class="form-control" id="employeeId" name="EmployeeId" placeholder="e.g., EMP001" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="department" class="form-label">Department</label>
                            <input type="text" class="form-control" id="department" name="Department" placeholder="e.g., IT, HR, Sales" />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="designation" class="form-label">Designation</label>
                            <input type="text" class="form-control" id="designation" name="Designation" placeholder="e.g., Software Engineer" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="phoneNumber" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phoneNumber" name="PhoneNumber" />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="dateOfJoining" class="form-label">Date of Joining</label>
                            <input type="date" class="form-control" id="dateOfJoining" name="DateOfJoining" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="isActive" class="form-label">Status</label>
                            <select class="form-select" id="isActive" name="IsActive">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label for="address" class="form-label">Address</label>
                            <textarea class="form-control" id="address" name="Address" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="submitBtn">Send Invitation</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Tabulator JS -->
    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <!-- SortableJS for drag-and-drop -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Ensure modal body is scrollable */
        #userModal .modal-dialog {
            max-height: 85vh;
            margin: 1.75rem auto;
        }

        #userModal .modal-content {
            max-height: 85vh;
        }

        #userModal .modal-body {
            max-height: calc(85vh - 120px);
            overflow-y: auto;
            padding: 1.5rem;
        }

        /* Custom scrollbar for better UX */
        #userModal .modal-body::-webkit-scrollbar {
            width: 8px;
        }

        #userModal .modal-body::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        #userModal .modal-body::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 4px;
        }

        #userModal .modal-body::-webkit-scrollbar-thumb:hover {
            background: #555;
        }

        /* Loading overlay */
        #userTable .tabulator-loader {
            font-size: 14px;
            padding: 20px;
            text-align: center;
            background: #fff;
        }
    </style>

    <script>
        let userModal = null;
        let userTable = null;
        let searchTimeout = null;
        let currentSearch = '';

        // Define table columns with visibility settings
        var TableFields = [
            {
                title: "#",
                field: "rownum",
                formatter: "rownum",
                hozAlign: "center",
                headerSort: false,
                width: 50,
                visible: true
            },
            {
                title: "Employee ID",
                field: "employeeId",
                hozAlign: "center",
                visible: true,
                formatter: function(cell) {
                    const value = cell.getValue();
                    return value ? `<span class="badge bg-info">${value}</span>` : '<span class="badge bg-secondary">N/A</span>';
                }
            },
            {
                title: "Username",
                field: "username",
                hozAlign: "left",
                visible: true,
                formatter: function(cell) {
                    return `<strong>${cell.getValue()}</strong>`;
                }
            },
            {
                title: "Email",
                field: "email",
                hozAlign: "left",
                visible: true
            },
            {
                title: "Full Name",
                field: "fullName",
                hozAlign: "left",
                visible: true
            },
            {
                title: "Department",
                field: "department",
                hozAlign: "left",
                visible: true,
                formatter: function(cell) {
                    const value = cell.getValue();
                    return value || "-";
                }
            },
            {
                title: "Designation",
                field: "designation",
                hozAlign: "left",
                visible: true,
                formatter: function(cell) {
                    const value = cell.getValue();
                    return value || "-";
                }
            },
            {
                title: "Role",
                field: "roleName",
                hozAlign: "center",
                visible: true,
                formatter: function(cell) {
                    const row = cell.getRow().getData();
                    return `<span class="badge bg-${row.roleBadge}">${row.roleName}</span>`;
                }
            },
            {
                title: "Status",
                field: "isActive",
                hozAlign: "center",
                visible: true,
                formatter: function(cell) {
                    const value = cell.getValue();
                    return value
                        ? '<span class="badge bg-success">Active</span>'
                        : '<span class="badge bg-secondary">Inactive</span>';
                }
            },
            {
                title: "Actions",
                field: "id",
                hozAlign: "center",
                headerSort: false,
                download: false,
                print: false,
                frozen: true,
                visible: true,
                formatter: function(cell) {
                    const row = cell.getRow().getData();
                    const id = row.id || '';
                    const username = (row.username || '').toString().replace(/'/g, "\\'");
                    const email = (row.email || '').toString().replace(/'/g, "\\'");
                    const fullName = (row.fullName || '').toString().replace(/'/g, "\\'");
                    const role = row.role || 0;
                    const employeeId = (row.employeeId || '').toString().replace(/'/g, "\\'");
                    const department = (row.department || '').toString().replace(/'/g, "\\'");
                    const designation = (row.designation || '').toString().replace(/'/g, "\\'");
                    const isActive = row.isActive || false;

                    return `
                        <button class="btn btn-sm btn-primary me-2"
                            onclick="openEditModalFromTable(
                                '${id}',
                                '${username}',
                                '${email}',
                                '${fullName}',
                                ${role},
                                '${employeeId}',
                                '${department}',
                                '${designation}',
                                ${isActive}
                            )">
                            <i class="bx bx-edit"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-danger" onclick="deleteUser('${id}', '${username}')">
                            <i class="bx bx-trash"></i> Delete
                        </button>
                    `;
                }
            }
        ];

        // Initialize modal and table on page load
        document.addEventListener('DOMContentLoaded', function() {
            userModal = new bootstrap.Modal(document.getElementById('userModal'));
            
            // Load column filter settings and initialize table
            UsersGear();
        });

        // Load column filter settings and initialize table
        function UsersGear() {
            $.ajax({
                url: '@Url.Action("GetFilteredColumn", "ColumnFilter")',
                type: 'GET',
                data: { type: 'Users' },
                success: function (response) {
                    console.log("GetFilteredColumn response:", response);
                    
                    if ((response.Success == 1 || response.success == 1) && response.data && response.data.keyValue) {
                        try {
                            const savedData = JSON.parse(response.data.keyValue);
                            console.log("Parsed saved data:", savedData);
                            
                            if (savedData.colDefs && Array.isArray(savedData.colDefs)) {
                                // Update TableFields visibility based on saved settings
                                savedData.colDefs.forEach(savedCol => {
                                    const tableCol = TableFields.find(col => col.field === savedCol.field);
                                    if (tableCol) {
                                        tableCol.visible = savedCol.visible !== undefined ? savedCol.visible : true;
                                    }
                                });
                                console.log("Updated TableFields:", TableFields);
                            }
                        } catch (e) {
                            console.error("Error parsing saved columns:", e);
                        }
                    }
                    populateCheckbox();
                    initializeUserTable();
                    setupSearchFilter();
                    setupExportButtons();
                    setupColumnFilterSave();
                },
                error: function (error) {
                    console.error("Error fetching column settings:", error);
                    populateCheckbox();
                    initializeUserTable();
                    setupSearchFilter();
                    setupExportButtons();
                    setupColumnFilterSave();
                }
            });
        }

        // Populate column filter checkboxes
        function populateCheckbox() {
            let items = TableFields
                .filter(x => x.field !== 'id') // Exclude actions column
                .map(x => {
                    return `
                        <li class="d-flex justify-content-between align-items-center px-3 py-1 draggable-item" data-field="${x.field}">
                            <span class="d-flex align-items-center">
                                <i class="bx bx-menu me-2 handle" style="cursor: move;"></i> ${x.title}
                            </span>
                            <div class="form-check form-switch">
                                <input class="form-check-input toggle-column users-column" type="checkbox" role="switch"
                                       id="${x.field}" value="${x.field}" ${x.visible ? 'checked' : ''}
                                       onclick="showHideColumn('${x.field}')">
                            </div>
                        </li>`;
                });

            const columnList = document.getElementById('UsersColumnList');
            columnList.innerHTML = items.join('');
            enableDragAndDrop();
        }

        // Enable drag and drop for column ordering
        function enableDragAndDrop() {
            new Sortable(document.getElementById('UsersColumnList'), {
                animation: 200,
                handle: '.handle',
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                dragClass: 'sortable-drag',
                forceFallback: true,
                fallbackTolerance: 5,
                scroll: true,
                scrollSensitivity: 30,
                scrollSpeed: 10,
                onEnd: function (evt) {
                    updateColumnOrder();
                }
            });
        }

        // Update column order based on drag and drop
        function updateColumnOrder() {
            let newOrder = [];
            document.querySelectorAll('#UsersColumnList .draggable-item').forEach(item => {
                const field = item.getAttribute('data-field');
                const title = item.querySelector('span').innerText.trim();
                const visible = item.querySelector('input').checked;
                newOrder.push({ field: field, title: title, visible: visible });
            });

            let allColumns = userTable.getColumns().map(col => col.getDefinition());
            let fixedColumns = allColumns.filter(col => col.field === 'id');
            let newColumns = newOrder.map(col => {
                let existingColumn = userTable.getColumn(col.field);
                return existingColumn ? existingColumn.getDefinition() : { title: col.title, field: col.field, visible: col.visible };
            });

            newColumns = [...newColumns, ...fixedColumns];
            userTable.setColumns(newColumns);

            // Re-populate checkboxes
            populateCheckbox();
        }

        // Show/hide individual column
        function showHideColumn(colName) {
            userTable.toggleColumn(colName);
        }

        // Save column filter settings
        function setupColumnFilterSave() {
            $("#saveUsersFilter").on("click", function () {
                var colDefs = userTable.getColumnDefinitions();

                $(".users-column").each(function () {
                    var field = $(this).val();
                    var isVisible = $(this).is(":checked");

                    colDefs.forEach(function (colDef) {
                        if (colDef.field === field) {
                            colDef.visible = isVisible;
                        }
                    });
                });

                var filteredColDefs = colDefs.filter(colDef => colDef.field !== 'id');
                var finaldata = { colDefs: filteredColDefs };
                var jsonData = JSON.stringify(finaldata);

                console.log("Saving column filter:", jsonData);

                $.ajax({
                    url: '@Url.Action("ColumnFilterCreation", "ColumnFilter")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ keyValue: jsonData, type: 'Users' }),
                    success: function (response) {
                        console.log("Save response:", response);
                        // Handle both Success and success (case-insensitive)
                        if (response.Success === 1 || response.success === 1 || response.Success === true || response.success === true) {
                            toastr.success(response.Message || response.message || "Filter saved successfully", "Success", { "toastClass": "toast-green" });
                            $('#dropdownMenuButton1').dropdown('hide');
                        } else {
                            toastr.error(response.Message || response.message || "Unknown error", "Error");
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Save error:", xhr.responseText, status, error);
                        // Try to parse error response
                        try {
                            var errResponse = JSON.parse(xhr.responseText);
                            toastr.error(errResponse.Message || errResponse.message || "Error saving filter settings.", "Error");
                        } catch (e) {
                            toastr.error("Error saving filter settings.", "Error");
                        }
                    }
                });
            });
        }

        // Delete column filter settings
        function DeleteFilter_Users(data) {
            $.ajax({
                url: '@Url.Action("DeleteColumnFilter", "ColumnFilter")',
                type: "GET",
                data: { type: data },
                success: function (response) {
                    console.log("Delete response:", response);
                    if (response.Success == 1 || response.success == 1) {
                        toastr.success(response.Message || response.message || "Deleted successfully", "Success", { "toastClass": "toast-green" });
                        UsersGear();
                    } else {
                        toastr.error(response.Message || response.message || "Error deleting filter", "Error", { "toastClass": "toast-red" });
                    }
                },
                error: function (xhr, status, error) {
                    console.error("Delete error:", xhr.responseText);
                    toastr.error("Error during delete.", "Error", { "toastClass": "toast-red" });
                }
            });
        }

        // Close dropdown when clicking outside
        document.addEventListener("click", function (event) {
            let dropdown = document.querySelector(".gear-dropdown1");
            let button = document.getElementById("dropdownMenuButton1");
            if (dropdown && button && !dropdown.contains(event.target) && !button.contains(event.target)) {
                dropdown.classList.remove("show");
            }
        });

        document.querySelector(".gear-dropdown1").addEventListener("click", function (event) {
            event.stopPropagation();
        });

        // Initialize Tabulator with server-side pagination
        function initializeUserTable() {
            userTable = new Tabulator("#userTable", {
                ajaxURL: '@Url.Action("GetUsersData", "Users")',
                ajaxParams: function() {
                    return {
                        search: currentSearch
                    };
                },
                ajaxConfig: "GET",
                ajaxFiltering: true,
                ajaxSorting: true,
                pagination: "remote",
                paginationSize: 10,
                paginationSizeSelector: [10, 25, 50, 100],
                paginationButtonCount: 5,
                movableColumns: true,
                resizableRows: false,
                initialSort: [
                    { column: "createdAt", dir: "desc" }
                ],
                ajaxResponse: function(url, params, response) {
                    console.log("Response type:", typeof response);
                    console.log("Response received:", response);

                    // Check if response is a string (not parsed)
                    if (typeof response === 'string') {
                        try {
                            response = JSON.parse(response);
                        } catch(e) {
                            console.error("Failed to parse JSON:", e);
                            return [];
                        }
                    }

                    // Set pagination total for Tabulator 5.x
                    var table = this;
                    if (response.total && table.modules && table.modules.pagination) {
                        table.modules.pagination._setTotal(response.total);
                    }

                    // For Tabulator 5.x remote pagination, return only the data array
                    return response.data || [];
                },
                columns: TableFields,
                locale: "en",
                langs: {
                    "en": {
                        "pagination": {
                            "first": "First",
                            "prev": "Previous",
                            "next": "Next",
                            "last": "Last",
                            "all": "All",
                            "counter": "Showing {from} to {to} of {count} entries"
                        }
                    }
                }
            });
        }

        // Setup search filter
        function setupSearchFilter() {
            document.getElementById('searchInput').addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    currentSearch = e.target.value;
                    if (userTable) {
                        userTable.setPage(1);
                        userTable.replaceData();
                    }
                }, 500); // 500ms debounce
            });
        }

        // Setup export buttons
        function setupExportButtons() {
            document.getElementById('exportCsvBtn').addEventListener('click', function() {
                if (!userTable) {
                    return;
                }

                userTable.download("csv", "users.csv");
            });

            document.getElementById('exportExcelBtn').addEventListener('click', function() {
                if (!userTable) {
                    return;
                }

                userTable.download("xlsx", "users.xlsx", { sheetName: "Users" });
            });

            document.getElementById('exportPdfBtn').addEventListener('click', function() {
                if (!userTable) {
                    return;
                }

                userTable.download("pdf", "users.pdf", {
                    orientation: "landscape",
                    autoTable: {
                        theme: "grid"
                    }
                });
            });
        }

        // Open Edit Modal from Tabulator
        function openEditModalFromTable(id, username, email, fullName, role, employeeId, department, designation, isActive) {
            // Split full name into first and last name
            const nameParts = fullName.split(' ');
            const firstName = nameParts[0] || '';
            const lastName = nameParts.slice(1).join(' ') || '';
            
            openEditModal(
                id,
                username,
                email,
                firstName,
                lastName,
                role,
                employeeId,
                department,
                designation,
                '', // phoneNumber not in table
                '', // address not in table
                '', // dateOfJoining not in table
                isActive.toString().toLowerCase()
            );
        }

        // Open Create Modal
        function openCreateModal() {
            document.getElementById('modalTitle').textContent = 'Invite User';
            document.getElementById('formAction').value = 'create';
            document.getElementById('userForm').reset();
            document.getElementById('userId').value = '';
            document.getElementById('username').readOnly = false;
            document.getElementById('invitationNotice').style.display = 'block';
            document.getElementById('submitBtn').textContent = 'Send Invitation';
            document.getElementById('isActive').value = 'true';
            clearErrors();
        }

        // Open Edit Modal
        function openEditModal(id, username, email, firstName, lastName, role, employeeId, department, designation, phoneNumber, address, dateOfJoining, isActive) {
            document.getElementById('modalTitle').textContent = 'Edit User';
            document.getElementById('formAction').value = 'edit';
            document.getElementById('userId').value = id;
            document.getElementById('username').value = username;
            document.getElementById('username').readOnly = true;
            document.getElementById('email').value = email;
            document.getElementById('firstName').value = firstName || '';
            document.getElementById('lastName').value = lastName || '';
            document.getElementById('role').value = role;
            document.getElementById('employeeId').value = employeeId || '';
            document.getElementById('department').value = department || '';
            document.getElementById('designation').value = designation || '';
            document.getElementById('phoneNumber').value = phoneNumber || '';
            document.getElementById('address').value = address || '';
            document.getElementById('dateOfJoining').value = dateOfJoining || '';
            document.getElementById('isActive').value = isActive;
            document.getElementById('invitationNotice').style.display = 'none';
            document.getElementById('submitBtn').textContent = 'Update User';
            clearErrors();
            
            // Show the modal
            if (userModal) {
                userModal.show();
            } else {
                userModal = new bootstrap.Modal(document.getElementById('userModal'));
                userModal.show();
            }
        }

        // Clear validation errors
        function clearErrors() {
            document.querySelectorAll('.text-danger').forEach(el => {
                if (!el.id || (el.id !== 'usernameError' && el.id !== 'emailError' && el.id !== 'roleError')) {
                    el.textContent = '';
                }
            });
            document.getElementById('usernameError').textContent = '';
            document.getElementById('emailError').textContent = '';
            document.getElementById('roleError').textContent = '';
        }

        // Form Submit Handler
        document.getElementById('userForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            clearErrors();

            const formData = new FormData(this);
            const action = document.getElementById('formAction').value;
            const url = action === 'create' ? '@Url.Action("Create", "Users")' : '@Url.Action("Edit", "Users")';

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();
                
                if (response.ok) {
                    // Close modal
                    if (userModal) {
                        userModal.hide();
                    }
                    
                    // Show success message
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: result.message || 'User saved successfully!',
                        timer: 2000
                    });
                    
                    // Reload page
                    setTimeout(() => location.reload(), 2000);
                } else {
                    // Handle validation errors
                    const errors = result.errors;
                    if (errors) {
                        for (const [key, value] of Object.entries(errors)) {
                            if (key === '__global') {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: value.join(' ')
                                });
                            } else {
                                const errorEl = document.getElementById(key.toLowerCase() + 'Error');
                                if (errorEl) {
                                    errorEl.textContent = value.join(' ');
                                }
                            }
                        }
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'An error occurred while saving the user.'
                });
            }
        });

        // Delete User
        function deleteUser(id, username) {
            Swal.fire({
                title: 'Are you sure?',
                html: `Do you want to delete user <strong>${username}</strong>?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const formData = new FormData();
                        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                        
                        const response = await fetch('@Url.Action("Delete", "Users")/' + id, {
                            method: 'POST',
                            body: formData
                        });

                        if (response.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Deleted!',
                                text: 'User has been deleted.',
                                timer: 2000
                            });
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: 'Failed to delete user.'
                            });
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: 'An error occurred while deleting the user.'
                        });
                    }
                }
            });
        }
    </script>
}

@functions {
    string GetRoleBadgeClass(SmartLeads.Domain.Enums.UserRole role)
    {
        return role switch
        {
            SmartLeads.Domain.Enums.UserRole.SuperAdmin => "danger",
            SmartLeads.Domain.Enums.UserRole.Admin => "primary",
            SmartLeads.Domain.Enums.UserRole.Manager => "info",
            _ => "secondary"
        };
    }

    string GetRoleDisplayName(SmartLeads.Domain.Enums.UserRole role)
    {
        return role switch
        {
            SmartLeads.Domain.Enums.UserRole.SuperAdmin => "Super Admin",
            SmartLeads.Domain.Enums.UserRole.Admin => "Admin",
            SmartLeads.Domain.Enums.UserRole.Manager => "Manager",
            _ => "User"
        };
    }
}
